import cors from 'cors'
import 'dotenv/config'
import express from 'express'
import multer from 'multer'
import fs from 'fs'
import path from 'path'
import { fileURLToPath } from 'url'
import bcrypt from 'bcryptjs'
import jwt from 'jsonwebtoken'

const __filename = fileURLToPath(import.meta.url)
const __dirname = path.dirname(__filename)
const app = express()
app.use(cors({
  origin: ['http://localhost:5173', 'http://localhost:3000', 'http://127.0.0.1:5173'],
  credentials: true,
  methods: ['GET', 'POST', 'PUT', 'DELETE', 'OPTIONS'],
  allowedHeaders: ['Content-Type', 'Authorization'],
}))
app.use(express.json())

const usersDB = path.join(__dirname, 'users.json')
const feedbackDB = path.join(__dirname, 'feedback.json')

const readDB = (dbPath) => {
  try {
    const data = fs.readFileSync(dbPath, 'utf8');
    return JSON.parse(data);
  } catch (error) {
    console.error(`Error reading ${dbPath}:`, error);
    return [];
  }
};

const writeDB = (dbPath, data) => {
  try {
    fs.writeFileSync(dbPath, JSON.stringify(data, null, 2));
  } catch (error) {
    console.error(`Error writing to ${dbPath}:`, error);
  }
};

const createAdmin = async () => {
    const users = readDB(usersDB);
    const adminExists = users.some(user => user.username === 'admin');
    if (!adminExists) {
        const salt = await bcrypt.genSalt(10);
        const hashedPassword = await bcrypt.hash('admin', salt);
        users.push({ id: Date.now(), username: 'admin', password: hashedPassword, isAdmin: true });
        writeDB(usersDB, users);
        console.log('Admin user created');
    }
};

createAdmin();

app.post('/api/register', async (req, res) => {
    const { username, password } = req.body;
    if (!username || !password) {
        return res.status(400).json({ error: '鐢ㄦ埛鍚嶅拰瀵嗙爜涓嶈兘涓虹┖' });
    }

    const users = readDB(usersDB);
    if (users.some(user => user.username === username)) {
        return res.status(400).json({ error: 'User already exists' });
    }

    const salt = await bcrypt.genSalt(10);
    const hashedPassword = await bcrypt.hash(password, salt);
    const newUser = { id: Date.now(), username, password: hashedPassword, isAdmin: false };
    users.push(newUser);
    writeDB(usersDB, users);

    res.status(201).json({ message: '鐢ㄦ埛鍒涘缓鎴愬姛' });
});

app.post('/api/login', async (req, res) => {
    const { username, password } = req.body;
    if (!username || !password) {
        return res.status(400).json({ error: '鐢ㄦ埛鍚嶅拰瀵嗙爜涓嶈兘涓虹┖' });
    }

    const users = readDB(usersDB);
    const user = users.find(user => user.username === username);
    if (!user) {
        return res.status(400).json({ error: '鐢ㄦ埛鍚嶆垨瀵嗙爜閿欒' });
    }

    const isMatch = await bcrypt.compare(password, user.password);
    if (!isMatch) {
        return res.status(400).json({ error: '鐢ㄦ埛鍚嶆垨瀵嗙爜閿欒' });
    }

    const token = jwt.sign({ id: user.id, username: user.username, isAdmin: user.isAdmin }, 'your_jwt_secret', { expiresIn: '1h' });
    res.json({ token });
});

const auth = (req, res, next) => {
    const token = req.header('Authorization')?.replace('Bearer ', '');
    if (!token) {
        return res.status(401).json({ error: '鏈彁渚涗护鐗岋紝鎺堟潈澶辫触' });
    }

    try {
        const decoded = jwt.verify(token, 'your_jwt_secret');
        req.user = decoded;
        next();
    } catch (error) {
        res.status(401).json({ error: '浠ょ墝鏃犳晥' });
    }
};

const admin = (req, res, next) => {
    if (!req.user.isAdmin) {
        return res.status(403).json({ error: '璁块棶琚嫆缁? });
    }
    next();
};

app.post('/api/feedback', auth, (req, res) => {
    const { message } = req.body;
    if (!message) {
        return res.status(400).json({ error: '鍙嶉淇℃伅涓嶈兘涓虹┖' });
    }

    const feedback = readDB(feedbackDB);
    const newFeedback = { 
        id: Date.now(), 
        userId: req.user.id, 
        username: req.user.username, 
        message, 
        createdAt: new Date().toISOString() 
    };
    feedback.push(newFeedback);
    writeDB(feedbackDB, feedback);

    res.status(201).json({ message: '鍙嶉鎻愪氦鎴愬姛' });
});

app.get('/api/feedback', auth, admin, (req, res) => {
    const feedback = readDB(feedbackDB);
    res.json(feedback);
});

app.delete('/api/feedback/:id', auth, admin, (req, res) => {
    const { id } = req.params;
    let feedback = readDB(feedbackDB);
    const initialLength = feedback.length;
    feedback = feedback.filter(item => item.id !== parseInt(id));

    if (feedback.length === initialLength) {
        return res.status(404).json({ error: '鏈壘鍒板弽棣? });
    }

    writeDB(feedbackDB, feedback);
    res.json({ message: '鍙嶉鍒犻櫎鎴愬姛' });
});

// 鐢?multer 澶勭悊 multipart/form-data锛堜笉瑕佺敤 express.json 瑙ｆ瀽鍥剧墖涓婁紶锛?
const upload = multer({
  storage: multer.memoryStorage(),
  limits: { fileSize: 10 * 1024 * 1024 },
})

app.post('/api/identify', upload.single('images'), async (req, res) => {
  try {
    const apiKey =
      process.env.PLANTNET_API_KEY ||
      process.env.VITE_PLANTNET_API_KEY ||
      (typeof req.query['api-key'] === 'string' ? req.query['api-key'] : '')

    console.log('PlantNet 璇嗗埆璇锋眰:', {
      hasApiKey: !!apiKey,
      apiKeyPreview: apiKey ? apiKey.substring(0, 6) + '...' : 'N/A',
      fileName: req.file?.originalname,
      fileSize: req.file?.size,
    })

    if (!apiKey) {
      return res.status(400).json({ error: '缂哄皯 api-key (璇疯缃?PLANTNET_API_KEY 鎴?VITE_PLANTNET_API_KEY)' })
    }

    const file = req.file
    if (!file) {
      return res.status(400).json({ error: '缂哄皯鍥惧儚鏂囦欢瀛楁' })
    }

    const organ = typeof req.body.organs === 'string' && req.body.organs ? req.body.organs : 'flower'
    const lang = typeof req.query.lang === 'string' && req.query.lang ? req.query.lang : 'zh'
    const includeRelated =
      typeof req.query['include-related-images'] === 'string'
        ? req.query['include-related-images']
        : 'false'

    const url = new URL('https://my-api.plantnet.org/v2/identify/all')
    url.searchParams.set('api-key', apiKey)
    url.searchParams.set('lang', lang)
    url.searchParams.set('include-related-images', includeRelated)

    const form = new FormData()
    form.append('images', new Blob([file.buffer], { type: file.mimetype || 'application/octet-stream' }), file.originalname)
    form.append('organs', organ)

    console.log('鍚?PlantNet 鍙戦€佽姹?', url.toString())

    // 娉ㄦ剰锛氫笉瑕佹墜鍔ㄨ缃?Content-Type锛岃 fetch 鑷姩甯?boundary
    const resp = await fetch(url.toString(), {
      method: 'POST',
      body: form,
    })

    console.log('PlantNet 鍝嶅簲鐘舵€?', resp.status)

    if (!resp.ok) {
      const text = await resp.text().catch(() => '')
      console.error('PlantNet API 閿欒:', resp.status, text)
      return res.status(resp.status).json({ error: `PlantNet 閿欒: ${resp.status}`, detail: text })
    }

    const data = await resp.json()
    console.log('PlantNet 杩斿洖鏁版嵁:', data)
    return res.json(data)
  } catch (error) {
    const msg = error instanceof Error ? error.message : '鏈煡閿欒'
    console.error('璇嗚姳璇锋眰閿欒:', msg)
    return res.status(500).json({ error: msg })
  }
})

// Qwen API 浠ｇ悊绔偣
app.post('/api/chat', async (req, res) => {
  try {
    const apiKey = process.env.VITE_QWEN_API_KEY
    if (!apiKey) {
      return res.status(400).json({ error: '缂哄皯 VITE_QWEN_API_KEY' })
    }

    const messages = req.body.messages
    const knowledge = req.body.knowledge
    const plantContext = req.body.plantContext

    if (!Array.isArray(messages)) {
      return res.status(400).json({ error: '娑堟伅鏍煎紡鏃犳晥' })
    }

    let prompt = ''
    for (const msg of messages) {
      if (msg.role === 'system') {
        let systemContent = msg.content
        if (knowledge) {
          systemContent += `\n\n浣犺繕鍙互鍙傝€冧互涓嬬殑涓撳鐭ヨ瘑鏉ユ洿濂藉湴鍥炵瓟鐢ㄦ埛鐨勯棶棰橈細\n---\n${knowledge}\n---`
        }
        if (plantContext) {
          systemContent += `\n\n褰撳墠鐢ㄦ埛姝ｅ湪璇㈤棶鍏充簬銆?{plantContext}銆嶇殑闂锛岃浼樺厛鍥寸粫瀹冩潵鍥炵瓟銆俙
        }
        prompt += systemContent + '\n\n'
      } else if (msg.role === 'user') {
        prompt += `鐢ㄦ埛: ${msg.content}\n`
      } else if (msg.role === 'assistant') {
        prompt += `鍔╂墜: ${msg.content}\n`
      }
    }
    prompt += '鍔╂墜: '

    const response = await fetch('https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: 'qwen-plus',
        input: {
          prompt: prompt,
        },
        parameters: {
          temperature: 0.6,
          top_p: 0.8,
          max_tokens: 1500,
        },
      }),
    })

    const data = await response.json()
    
    if (!response.ok) {
      console.error('Qwen API error:', data)
      return res.status(response.status).json(data)
    }

    // 璋冭瘯锛氳褰旳I鍘熷鍝嶅簲
    console.log('AI鍘熷鍝嶅簲:', JSON.stringify(data, null, 2))
    
    return res.json(data)
  } catch (error) {
    const msg = error instanceof Error ? error.message : '鏈煡閿欒'
    console.error('Qwen proxy error:', msg)
    return res.status(500).json({ error: msg })
  }
})

// 鏂板锛欰I 鐢熸垚鍏绘姢瑕佺偣绔偣
app.post('/api/care-tips', async (req, res) => {
  try {
    const apiKey = process.env.VITE_QWEN_API_KEY;
    if (!apiKey) {
      return res.status(400).json({ error: '缂哄皯 VITE_QWEN_API_KEY' });
    }

    const { name, genus, family } = req.body;
    if (!name) {
      return res.status(400).json({ error: '缂哄皯妞嶇墿鍚嶇О' });
    }

    const prompt = `璇蜂负銆?{name}銆嶏紙${genus ? `灞? ${genus}, ` : ''}${family ? `绉? ${family}` : ''}锛夋彁渚涗笓涓氱殑鍏绘姢瑕佺偣銆傝鐐归渶瑕佽鐩栵細鍏夌収銆佹祰姘淬€佸湡澹ゃ€佹柦鑲ャ€佷慨鍓€傝涓ユ牸鎸夌収JSON鏍煎紡杩斿洖涓€涓瓧绗︿覆鏁扮粍锛屼緥濡傦細["瑕佺偣1", "瑕佺偣2", "瑕佺偣3"]銆備笉瑕佹坊鍔犱换浣曢澶栬鏄庢垨浠ｇ爜鍧楁爣璁般€俙;

    const response = await fetch('https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: 'qwen-plus',
        input: { prompt },
        parameters: { result_format: 'text' },
      }),
    });

    const data = await response.json();
    if (!response.ok) {
      console.error('Qwen API error for care tips:', data);
      return res.status(response.status).json(data);
    }

    const textResponse = data.output.text;
    let tips = [];
    try {
      tips = JSON.parse(textResponse);
      if (!Array.isArray(tips)) {
        tips = textResponse.split('\n').map(s => s.trim()).filter(Boolean);
      }
    } catch (e) {
      console.error('Failed to parse care tips JSON, falling back to text split:', textResponse);
      tips = textResponse.split('\n').map(s => s.trim()).filter(Boolean);
    }
      
    return res.json({ tips });

  } catch (error) {
    const msg = error instanceof Error ? error.message : '鏈煡閿欒';
    console.error('Care tips generation error:', msg);
    return res.status(500).json({ error: msg });
  }
});

// 鏂板锛欰I 缈昏瘧绔偣
app.post('/api/translate', async (req, res) => {
  try {
    const apiKey = process.env.VITE_QWEN_API_KEY;
    if (!apiKey) {
      return res.status(400).json({ error: '缂哄皯 VITE_QWEN_API_KEY' });
    }

    const { name } = req.body;
    if (!name) {
      return res.status(400).json({ error: '缂哄皯闇€瑕佺炕璇戠殑鍚嶇О' });
    }

    const prompt = `璇峰皢妞嶇墿鍒嗙被瀛﹀悕 "${name}" 缈昏瘧鎴愪腑鏂囥€傝鍙繑鍥炰腑鏂囧悕锛屼笉瑕佷换浣曞浣欑殑鏂囧瓧鎴栫鍙枫€俙;

    const response = await fetch('https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${apiKey}`,
      },
      body: JSON.stringify({
        model: 'qwen-plus',
        input: { prompt },
        parameters: { result_format: 'text' },
      }),
    });

    const data = await response.json();
    if (!response.ok) {
      console.error('Qwen API error for translation:', data);
      return res.status(response.status).json(data);
    }

    const translatedName = data.output.text.trim().replace(/["鈥溾€漖/g, '');
    return res.json({ translatedName });

  } catch (error) {
    const msg = error instanceof Error ? error.message : '鏈煡閿欒';
    console.error('Translation error:', msg);
    return res.status(500).json({ error: msg });
  }
});

app.use(express.static(path.join(__dirname, 'dist')));

// Fallback to index.html for client-side routing
app.get(/^(?!\/api).*/, (req, res) => {
  res.sendFile(path.join(__dirname, 'dist', 'index.html'));
});

app.listen(3001, '0.0.0.0', () => console.log('浠ｇ悊鏈嶅姟鍣ㄨ繍琛屽湪 http://127.0.0.1:3001'))


